{
  "info": {
    "name": "Kloka Attendance Platform API",
    "description": "System health, metrics, version, OpenAPI spec, tenant management, and JWT authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "kloka-platform-2026"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantKey",
      "value": "",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "platformKey",
      "value": "test-platform-key",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Live",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/live",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health", "live"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has status alive', () => pm.expect(pm.response.json().status).to.eql('alive'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Health Ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/ready",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health", "ready"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 503', () => pm.expect(pm.response.code).to.be.oneOf([200,503]));",
                  "pm.test('Body has status and database fields', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json).to.have.property('database');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "metrics"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is text/plain', () => pm.response.to.have.header('Content-Type', /text\\/plain/));"
                ]
              }
            }
          ]
        },
        {
          "name": "Version",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/version",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "version"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has version, build_time, git_commit', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.all.keys('version', 'build_time', 'git_commit');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "OpenAPI YAML",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/openapi.yaml",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "openapi.yaml"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is application/x-yaml', () => pm.response.to.have.header('Content-Type', 'application/x-yaml'));",
                  "pm.test('Body starts with openapi:', () => pm.expect(pm.response.text()).to.match(/^openapi:/));"
                ]
              }
            }
          ]
        },
        {
          "name": "OpenAPI JSON",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/openapi.json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "openapi.json"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is application/json', () => pm.response.to.have.header('Content-Type', 'application/json'));",
                  "pm.test('Valid OpenAPI doc', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('openapi');",
                  "  pm.expect(json.info).to.have.property('title');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Platform-Key",
                "value": "{{platformKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Retail Group\",\n  \"billing_email\": \"ops@acme.co.za\",\n  \"country_code\": \"ZA\",\n  \"legal_name\": \"Acme Retail (Pty) Ltd\",\n  \"tax_id\": \"1234567890\",\n  \"address_line1\": \"123 Main Street\",\n  \"city\": \"Johannesburg\",\n  \"postal_code\": \"2000\",\n  \"primary_contact_name\": \"John Doe\",\n  \"primary_contact_email\": \"john@acme.co.za\",\n  \"primary_contact_phone\": \"+27821234567\",\n  \"timezone\": \"Africa/Johannesburg\",\n  \"industry\": \"retail\",\n  \"subscription_plan\": \"pro\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenants"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response has tenant_id, name, tenant_key', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.all.keys('tenant_id', 'name', 'tenant_key', 'created_at');",
                  "  pm.collectionVariables.set('tenantId', json.tenant_id);",
                  "  pm.collectionVariables.set('tenantKey', json.tenant_key);",
                  "});",
                  "pm.test('Location header exists', () => pm.response.to.have.header('Location'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Tenant Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenantId}}\",\n  \"tenant_key\": \"{{tenantKey}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/tenant/authentication",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "tenant", "authentication"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.access_token);",
                  "pm.test('Has access_token', () => pm.expect(json.access_token).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "List Tenants (with JWT)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants?limit=10&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenants"],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                },
                {
                  "key": "offset",
                  "value": "0",
                  "disabled": false
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has data array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(Array.isArray(json.data)).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Tenant by ID (with JWT)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants/{{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenants", "{{tenantId}}"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response matches tenant', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.eql(pm.collectionVariables.get('tenantId'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "    pm.collectionVariables.set('baseUrl', 'http://localhost:8080');",
          "}",
          "if (!pm.collectionVariables.get('platformKey')) {",
          "    pm.collectionVariables.set('platformKey', 'test-platform-key');",
          "}"
        ]
      }
    }
  ]
}
